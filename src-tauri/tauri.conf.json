{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cat-rocket-converter",
  "version": "0.1.0",
  "identifier": "com.pixshrink",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cat-rocket-converter",
        "width": 428,
        "height": 318,
        "resizable": false,
        "decorations": true,
        "transparent": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": ["jpg", "jpeg"],
        "contentTypes": ["public.jpeg"],
        "mimeType": "image/jpeg",
        "name": "JPEG Image",
        "role": "Viewer",
        "rank": "Alternate"
      },
      {
        "ext": ["png"],
        "contentTypes": ["public.png"],
        "mimeType": "image/png",
        "name": "PNG Image",
        "role": "Viewer",
        "rank": "Alternate"
      },
      {
        "ext": ["heic"],
        "contentTypes": ["public.heic"],
        "mimeType": "image/heic",
        "name": "HEIC Image",
        "role": "Viewer",
        "rank": "Alternate"
      },
      {
        "ext": ["heif"],
        "contentTypes": ["public.heif"],
        "mimeType": "image/heif",
        "name": "HEIF Image",
        "role": "Viewer",
        "rank": "Alternate"
      }
    ],
    "icon": [
      "icons/icon.icns",
      "icons/128x128.png",
      "icons/icon.png"
    ]
  }
}
